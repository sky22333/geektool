<Window x:Class="GeekToolDownloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        mc:Ignorable="d"
        Title="极客工具下载器" Height="560" Width="860"
        MinWidth="860" MaxWidth="860" MinHeight="560" MaxHeight="560"
        WindowStyle="None" AllowsTransparency="False"
        Background="Transparent"
        Icon="pack://application:,,,/Assets/icons.ico"
        ResizeMode="CanResize" WindowStartupLocation="CenterScreen">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="-1" ResizeBorderThickness="0" CornerRadius="12"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <tb:TaskbarIcon x:Name="TrayIcon" ToolTipText="极客工具下载器" IconSource="/Assets/icons.ico" TrayMouseDoubleClick="TrayIcon_TrayMouseDoubleClick" PopupActivation="RightClick">
            <!-- Use TrayPopup for modern Win11 styled popup instead of classic ContextMenu -->
            <tb:TaskbarIcon.TrayPopup>
                <Border Background="{DynamicResource BgWindow}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="8" Padding="4" Width="120">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.25" Color="Black" />
                    </Border.Effect>
                    <StackPanel TextElement.Foreground="{DynamicResource TextP1}">
                        <Button Content="显示主界面" Click="TrayIcon_TrayMouseDoubleClick" Style="{DynamicResource ThemeButtonStyle}" HorizontalAlignment="Stretch" Margin="0,2"/>
                        <Border Height="1" Background="{DynamicResource Line}" Margin="4,4"/>
                        <Button Content="退出程序" Click="Exit_Click" Style="{DynamicResource ThemeButtonStyle}" HorizontalAlignment="Stretch" Margin="0,2"/>
                    </StackPanel>
                </Border>
            </tb:TaskbarIcon.TrayPopup>
        </tb:TaskbarIcon>

        <!-- Outer Border to provide actual app border -->
        <Border BorderThickness="1" BorderBrush="{DynamicResource Line}" 
                x:Name="RootBorder" Background="{DynamicResource BgWindow}" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Title Bar -->
                <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="极客工具下载器" Foreground="{DynamicResource ThemeAccent}" FontSize="11" 
                               FontWeight="Bold" Margin="20,0,0,0" VerticalAlignment="Center" />
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="🌐" Style="{StaticResource TitleBarButtonStyle}" Command="{Binding ShowAddPathDialogCommand}" ToolTip="添加到环境变量"/>
                        <Button Content="⚙" Style="{StaticResource TitleBarButtonStyle}" Command="{Binding OpenSettingsCommand}"/>
                        <Button Content="—" Style="{StaticResource TitleBarButtonStyle}" Click="Minimize_Click"/>
                        <Button Content="✕" Style="{StaticResource TitleBarButtonStyle}" Click="Close_Click"/>
                    </StackPanel>
                    
                    <Border Grid.ColumnSpan="2" VerticalAlignment="Bottom" Height="1" Background="{DynamicResource Line}"/>
                </Grid>

                <!-- View Stack -->
                <Grid Grid.Row="1">
                    <!-- Main View -->
                    <Grid x:Name="MainView" RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" x:Name="MainViewScale"/>
                        </Grid.RenderTransform>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="64"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Header -->
                        <Grid Grid.Row="0" Margin="25,15,25,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="320"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="#" Grid.Column="0" Foreground="{DynamicResource TextP2}" FontSize="10"/>
                            <TextBlock Text="名称" Grid.Column="1" Foreground="{DynamicResource TextP2}" FontSize="10"/>
                            <TextBlock Text="版本" Grid.Column="2" Foreground="{DynamicResource TextP2}" FontSize="10"/>
                            <TextBlock Text="状态" Grid.Column="3" Foreground="{DynamicResource TextP2}" FontSize="10" Margin="20,0,0,0"/>
                        </Grid>
                        <Border Grid.Row="0" VerticalAlignment="Bottom" Height="1" Background="{DynamicResource Line}"/>

                        <!-- List -->
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding Tools}" ScrollViewer.CanContentScroll="True" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling">
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ScrollViewer Padding="{TemplateBinding Padding}" Focusable="False" VerticalScrollBarVisibility="Hidden">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource Line}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource RowHover}"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource RowActive}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid Margin="25,16,25,16" Background="Transparent" MouseLeftButtonDown="Row_MouseLeftButtonDown">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="320"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Ellipse x:Name="StatusDot" Width="8" Height="8" Stroke="{DynamicResource TextP2}" StrokeThickness="2" HorizontalAlignment="Left"/>
                                            <TextBlock Text="{Binding Model.Name, Mode=OneTime}" Grid.Column="1" Foreground="{DynamicResource TextP1}" FontSize="14" FontWeight="Medium" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Model.Version, Mode=OneTime}" Grid.Column="2" Foreground="{DynamicResource TextP2}" FontFamily="Consolas" VerticalAlignment="Center"/>
                                            
                                            <StackPanel Grid.Column="3" Margin="20,0,0,0" VerticalAlignment="Center">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource ThemeAccent}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1" Margin="8,0,0,0"
                                                            Command="{Binding DataContext.OpenToolFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Visibility="{Binding IsOpenFolderVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                            ToolTip="打开安装目录"
                                                            Style="{StaticResource SmallIconButtonStyle}">
                                                        <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    </Button>
                                                </Grid>
                                                <TextBlock Text="{Binding TransferText}" Foreground="{DynamicResource TextP2}" FontSize="10" Margin="0,6,0,0"
                                                           Visibility="{Binding IsDownloading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter TargetName="StatusDot" Property="Fill" Value="{DynamicResource ThemeAccent}"/>
                                            <Setter TargetName="StatusDot" Property="Stroke" Value="{DynamicResource ThemeAccent}"/>
                                            <Setter TargetName="StatusDot" Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="{DynamicResource ThemeAccentColor}" BlurRadius="10" ShadowDepth="0" x:Name="ActiveShadow"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Footer -->
                        <Border Grid.Row="2" Background="{DynamicResource FooterBg}" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource Line}">
                            <Grid Margin="30,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="{Binding SelectAllButtonText}" Command="{Binding SelectAllToolsCommand}" Style="{StaticResource ThemeButtonStyle}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                                    <TextBlock Text="已选任务: " Foreground="{DynamicResource TextP2}" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedCount}" Foreground="{DynamicResource ThemeAccent}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button Grid.Column="3" Content="{Binding ActionButtonText}" Command="{Binding StartDownloadProcessCommand}"
                                        HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource DownloadButtonStyle}"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Settings View -->
                    <Grid x:Name="SettingsView" Opacity="0" Visibility="Collapsed" IsHitTestVisible="False" RenderTransformOrigin="0.5,0.5" Margin="45,25">
                        <Grid.RenderTransform>
                            <ScaleTransform ScaleX="1.1" ScaleY="1.1" x:Name="SettingsViewScale"/>
                        </Grid.RenderTransform>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,30">
                            <TextBlock Text="控制中心" Foreground="{DynamicResource TextP1}" FontSize="18" FontWeight="SemiBold"/>
                            <Border Background="{DynamicResource TabBg}" CornerRadius="6" HorizontalAlignment="Right" Margin="4">
                                <StackPanel Orientation="Horizontal" x:Name="TabStack">
                                    <RadioButton x:Name="TabGeneral" Content="通用偏好" GroupName="SettingsTab" IsChecked="True" Style="{DynamicResource TabRadioButtonStyle}"/>
                                    <RadioButton x:Name="TabEngine" Content="下载引擎" GroupName="SettingsTab" Style="{DynamicResource TabRadioButtonStyle}"/>
                                    <RadioButton x:Name="TabSecurity" Content="高级安全" GroupName="SettingsTab" Style="{DynamicResource TabRadioButtonStyle}"/>
                                    <Button Command="{Binding CloseSettingsCommand}" Style="{DynamicResource TabCloseButtonStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" Margin="0,0,6,0" VerticalAlignment="Center" FontSize="12"/>
                                            <TextBlock Text="返回" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                            <StackPanel>
                                <!-- General Tab Content -->
                                <StackPanel Visibility="{Binding IsChecked, ElementName=TabGeneral, Converter={StaticResource BoolToVisConverter}}">
                                    <TextBlock Text="基础设置" Style="{StaticResource GroupLabelStyle}"/>
                                    <Border Style="{StaticResource SettingCardStyle}">
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock Text="开机自启动" Style="{StaticResource CardLabelStyle}"/>
                                                <TextBlock Text="系统登录后自动后台挂载分发引擎" Style="{StaticResource CardDescStyle}"/>
                                            </StackPanel>
                                            <CheckBox IsChecked="{Binding Settings.AutoStart}" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource ToggleSwitchStyle}"/>
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="主题设置" Style="{StaticResource GroupLabelStyle}" Margin="0,20,0,15"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                                        <Button Content="跟随系统" Click="AutoTheme_Click" Style="{StaticResource ThemeButtonStyle}"/>
                                        <Button Content="深邃暗色" Click="DarkTheme_Click" Style="{StaticResource ThemeButtonStyle}" Margin="10,0,0,0"/>
                                        <Button Content="极简亮色" Click="LightTheme_Click" Style="{StaticResource ThemeButtonStyle}" Margin="10,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Download Engine Tab Content -->
                                <StackPanel Visibility="{Binding IsChecked, ElementName=TabEngine, Converter={StaticResource BoolToVisConverter}}">
                                    <TextBlock Text="传输引擎" Style="{StaticResource GroupLabelStyle}"/>
                                    <Border Style="{StaticResource SettingCardStyle}">
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock Text="最大下载并发数" Style="{StaticResource CardLabelStyle}"/>
                                                <TextBlock Text="同时进行数据同步的任务流上限" Style="{StaticResource CardDescStyle}"/>
                                            </StackPanel>
                                            <TextBox Text="{Binding Settings.MaxConcurrentDownloads}" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource MiniInputStyle}"/>
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingCardStyle}">
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock Text="远端工具清单 (JSON) URL" Style="{StaticResource CardLabelStyle}"/>
                                                <TextBlock Text="支持从远端拉取最新 tools.json 自动覆盖本地缓存" Style="{StaticResource CardDescStyle}"/>
                                                <TextBox Text="{Binding Settings.RemoteListUrl}" Margin="0,16,0,0" Style="{StaticResource ModernInputStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingCardStyle}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <StackPanel>
                                                    <TextBlock Text="网络代理设置" Style="{StaticResource CardLabelStyle}"/>
                                                    <TextBlock Text="支持 HTTP/SOCKS5 代理分发 (例如 socks5://127.0.0.1:10808)" Style="{StaticResource CardDescStyle}"/>
                                                </StackPanel>
                                                <CheckBox IsChecked="{Binding Settings.ProxyEnabled}" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource ToggleSwitchStyle}"/>
                                            </Grid>
                                            <TextBox Grid.Row="1" Text="{Binding Settings.ProxyUrl}" Visibility="{Binding Settings.ProxyEnabled, Converter={StaticResource BoolToVisConverter}}" Margin="0,16,0,0" Style="{StaticResource ModernInputStyle}" />
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <!-- Advanced Security Tab Content -->
                                <StackPanel Visibility="{Binding IsChecked, ElementName=TabSecurity, Converter={StaticResource BoolToVisConverter}}">
                                    <TextBlock Text="安全验证" Style="{StaticResource GroupLabelStyle}"/>
                                    <Border Style="{StaticResource SettingCardStyle}">
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock Text="哈希完整性校验" Style="{StaticResource CardLabelStyle}"/>
                                                <TextBlock Text="安装前自动比对 MD5/SHA256 摘要确保安装包未被篡改" Style="{StaticResource CardDescStyle}"/>
                                            </StackPanel>
                                            <CheckBox IsChecked="{Binding Settings.VerifyHash}" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource ToggleSwitchStyle}"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <!-- Add Path Dialog Overlay (Independent Layer) -->
                <Grid x:Name="AddPathDialog" Opacity="0" Visibility="Collapsed" IsHitTestVisible="False" Grid.RowSpan="2">
                    <!-- Dialog Card -->
                    <Border Background="{DynamicResource BgWindow}" BorderBrush="{DynamicResource ThemeAccent}" BorderThickness="2" 
                            CornerRadius="16" Width="520" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource ThemeAccentColor}" BlurRadius="50" ShadowDepth="0" Opacity="0.25"/>
                        </Border.Effect>
                        <StackPanel Margin="32,28,32,28">
                            <TextBlock Text="添加到环境变量" Foreground="{DynamicResource TextP1}" 
                                       FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBlock Text="输入要添加到 PATH 的文件夹路径" Foreground="{DynamicResource TextP2}" 
                                       FontSize="12" Margin="0,0,0,20"/>
                            
                            <TextBox x:Name="PathInputBox" Text="{Binding PathInputText, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource ModernInputStyle}" Height="40" FontSize="13"
                                     VerticalContentAlignment="Center" Padding="14,0" FontFamily="Consolas" Margin="0,0,0,24"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="取消" Command="{Binding CloseAddPathDialogCommand}" 
                                        Style="{StaticResource ThemeButtonStyle}" Width="80" Height="36" FontSize="13" Padding="0"/>
                                <Button Content="添加" Command="{Binding ConfirmAddPathCommand}" 
                                        Style="{StaticResource DownloadButtonStyle}" Width="80" Height="36" Margin="12,0,0,0" FontSize="13" Padding="0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
