<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="ThemeAccentColor">#005FB8</Color>
    <SolidColorBrush x:Key="ThemeAccent" Color="{StaticResource ThemeAccentColor}"/>
    <SolidColorBrush x:Key="BgBody" Color="#f0f2f5"/>
    <SolidColorBrush x:Key="BgWindow" Color="#EBffffff"/> <!-- 0.92 alpha roughly -->
    <SolidColorBrush x:Key="Line" Color="#12000000"/> <!-- 0.07 alpha -->
    <SolidColorBrush x:Key="TextP1" Color="#1c1c1e"/>
    <SolidColorBrush x:Key="TextP2" Color="#636366"/>
    <SolidColorBrush x:Key="RowHover" Color="#08000000"/> <!-- 0.03 alpha -->
    <SolidColorBrush x:Key="ItemBg" Color="#f9f9fb"/>
    <SolidColorBrush x:Key="FooterBg" Color="#CCf2f2f7"/> <!-- 0.8 alpha -->
    <SolidColorBrush x:Key="TabBg" Color="#0d000000"/> <!-- 0.05 alpha -->
    <SolidColorBrush x:Key="RowActive" Color="#14005FB8"/> <!-- 0.08 alpha -->
    <Color x:Key="AcrylicColor">#ffffff</Color>
</ResourceDictionary>
